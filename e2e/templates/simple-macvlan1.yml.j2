---
apiVersion: "k8s.cni.cncf.io/v1"
kind: NetworkAttachmentDefinition
metadata:
  name: macvlan1-config
spec: 
  config: '{
            "cniVersion": "{{ CNI_VERSION }}",
            "plugins": [
                {
                    "type": "macvlan",
                    "capabilities": { "ips": true },
                    "master": "{{ MACVLAN_MASTER_INTERFACE }}",
                    "mode": "bridge",
                    "ipam": {
                        "type": "static"
                    }
                }, {
                    "type": "tuning"
                } ]
        }'
---
apiVersion: v1
kind: Pod
metadata:
  name: macvlan1-worker1
  annotations:
    k8s.v1.cni.cncf.io/networks: '[
            { "name": "macvlan1-config",
              "ips": [ "10.1.1.11/24" ] }
    ]'
  labels:
    app: macvlan
spec:
  containers:
  - name: macvlan-worker1
    image: {{ E2E_POD_IMAGE }}
    command:
    - /bin/bash
    - -lc
    - |
      set -euxo pipefail
      if ! command -v ip >/dev/null 2>&1; then
        if command -v dnf >/dev/null 2>&1; then
          dnf install -y iproute
        else
          microdnf install -y iproute
        fi
      fi
      trap : TERM INT
      sleep infinity & wait
    securityContext:
      privileged: true
  nodeName: {{ TARGET_NODE_1 }}
---
apiVersion: v1
kind: Pod
metadata:
  name: macvlan1-worker2
  annotations:
    k8s.v1.cni.cncf.io/networks: '[
            { "name": "macvlan1-config",
              "ips": [ "10.1.1.12/24" ] }
    ]'
  labels:
    app: macvlan
spec:
  containers:
  - name: macvlan-worker2
    image: {{ E2E_POD_IMAGE }}
    command:
    - /bin/bash
    - -lc
    - |
      set -euxo pipefail
      if ! command -v ip >/dev/null 2>&1; then
        if command -v dnf >/dev/null 2>&1; then
          dnf install -y iproute
        else
          microdnf install -y iproute
        fi
      fi
      trap : TERM INT
      sleep infinity & wait
    securityContext:
      privileged: true
  nodeName: {{ TARGET_NODE_2 }}
